<div class="column is-one-third">
  <div class="card">
    <% if customer.image.attached? %>
      <div class="card-image">
        <figure class="image is-4by3">
          <%= image_tag customer.image.variant(resize_to_fill: [400, 300]), alt: customer.full_name, style: "object-fit: cover;" %>
        </figure>
      </div>
    <% end %>

    <div class="card-content">
      <p class="title is-4"><%= customer.full_name %></p>

      <div class="content">
        <p><strong>Phone:</strong> <%= customer.phone_number %></p>
        <p><strong>Email:</strong>
          <%= customer.email_address.present? ? customer.email_address : content_tag(:span, "Missing", class: "tag is-danger") %>
        </p>
        <p class="is-italic"><%= customer.notes %></p>
      </div>
    </div>
  </div>
</div>